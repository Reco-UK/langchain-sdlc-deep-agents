# Copy to .env for local development: `cp .env.example .env`
# In CI/CD and Cloud Run, these are injected as GitHub Secrets / GCP Secret
# Manager entries — never commit a real .env file.

# --- Environment ---------------------------------------------------------
ENVIRONMENT=local                      # local | ci | staging | production

# --- LLM Providers --------------------------------------------------------
DEFAULT_PROVIDER=ollama                # local dev default
FALLBACK_PROVIDER=                     # openai (unset locally, set in cloud)
OLLAMA_BASE_URL=http://ollama:11434
ANTHROPIC_API_KEY=                     # optional locally, required in prod
OPENAI_API_KEY=                        # optional, used as fallback provider

# --- State: Postgres (checkpoints) ----------------------------------------
POSTGRES_DSN=postgresql://agent:secret@postgres:5432/agentforge
# CI uses an in-memory SQLite checkpointer instead: sqlite:///memory.db

# --- State: Redis (semantic cache) -----------------------------------------
REDIS_URL=redis://redis:6379

# --- State: Vector DB (Qdrant) ----------------------------------------------
VECTOR_DB_URL=http://qdrant:6333

# --- Contextual Ingestion ---------------------------------------------------
CONTEXT_SOURCE=github                  # github (local/CI) | jira (enterprise)

# --- GitHub -----------------------------------------------------------------
GITHUB_TOKEN=ghp_xxxxx
GITHUB_REPO=                           # owner/repo, injected by CI
GITHUB_ISSUE_NUMBER=                   # injected by CI/webhook
GITHUB_WEBHOOK_SECRET=                 # required in staging/production; unset locally skips verification

# --- JIRA (points at the local twin-jira mock by default) -------------------
JIRA_URL=http://jira-mock:8080
JIRA_API_TOKEN=
JIRA_KEY=

# --- Confluence (points at the local mock-mock mock by default) -------------
CONFLUENCE_URL=http://confluence-mock:8081
CONFLUENCE_API_TOKEN=

# --- GCP (Cloud Run / Cloud Tasks / Cloud Scheduler) -------------------------
GCP_PROJECT=your-project-id
GCP_LOCATION=us-central1
TASK_QUEUE=agent-tasks
CLOUD_RUN_URL=                         # e.g. agentforge-xyz-uc.a.run.app
TASK_SA_EMAIL=                         # task-sa@your-project-id.iam.gserviceaccount.com

# --- Headless CLI task input -------------------------------------------------
TASK=                                  # e.g. "Fix login bug PROJ-123"

# --- Sandbox ------------------------------------------------------------------
WORKSPACE_ROOT=/workspace              # root that shell/filesystem MCP servers are jailed to
